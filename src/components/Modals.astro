<!-- Welcome modal (shows on first visit) -->
<div class="modal-backdrop" id="welcome-modal" role="dialog" aria-modal="true" aria-labelledby="welcome-title">
  <div class="modal">
    <div class="modal__logo" aria-hidden="true">
      <svg viewBox="-20 -165 280 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 23 -100 Q 23 -160 60 -160 L 85 -160 L 85 -150 L 62 -150 Q 33 -150 33 -100 L 33 0 L 23 0 Z" fill="currentColor"/>
        <rect x="-17" y="-105" width="286" height="10" fill="currentColor"/>
        <rect x="50" y="-95" width="10" height="95" fill="currentColor"/>
        <rect x="50" y="-55" width="42" height="10" fill="currentColor"/>
        <rect x="50" y="-10" width="48" height="10" fill="currentColor"/>
        <path d="M 115 -80 L 125 -80 L 165 -15 L 165 -80 L 175 -80 L 175 0 L 165 0 L 125 -65 L 125 0 L 115 0 Z" fill="currentColor"/>
        <path d="M 192 -80 L 202 -80 L 242 -15 L 242 -80 L 252 -80 L 252 0 L 242 0 L 202 -65 L 202 0 L 192 0 Z" fill="currentColor"/>
      </svg>
    </div>
    
    <p class="modal__text" id="welcome-title">Welcome to Fenn.</p>
    <p class="modal__text">
      We are a fictional company built as an independent GRC portfolio project. Third-party vendor names referenced throughout this site are real companies, but no affiliation or endorsement exists or is implied.
    </p>
    
    <button class="modal__btn" id="dismiss-welcome">I understand</button>
  </div>
</div>

<!-- Contact modal (opens when Contact us is clicked) -->
<div class="modal-backdrop" id="contact-modal" role="dialog" aria-modal="true" aria-labelledby="contact-title">
  <div class="modal">
    <button class="modal__close" id="close-contact" aria-label="Close">×</button>
    
    <div class="modal__logo" aria-hidden="true">
      <svg viewBox="-20 -165 280 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 23 -100 Q 23 -160 60 -160 L 85 -160 L 85 -150 L 62 -150 Q 33 -150 33 -100 L 33 0 L 23 0 Z" fill="currentColor"/>
        <rect x="-17" y="-105" width="286" height="10" fill="currentColor"/>
        <rect x="50" y="-95" width="10" height="95" fill="currentColor"/>
        <rect x="50" y="-55" width="42" height="10" fill="currentColor"/>
        <rect x="50" y="-10" width="48" height="10" fill="currentColor"/>
        <path d="M 115 -80 L 125 -80 L 165 -15 L 165 -80 L 175 -80 L 175 0 L 165 0 L 125 -65 L 125 0 L 115 0 Z" fill="currentColor"/>
        <path d="M 192 -80 L 202 -80 L 242 -15 L 242 -80 L 252 -80 L 252 0 L 242 0 L 202 -65 L 202 0 L 192 0 Z" fill="currentColor"/>
      </svg>
    </div>
    
    <p class="modal__text" id="contact-title">Fenn is fictional, but the work is real.</p>
    <p class="modal__text">To talk about this project or other work, get in touch here.</p>
    
    <div class="modal__buttons">
      <a href="mailto:hello@wichman.io" class="modal__btn">Email</a>
      <a href="https://linkedin.com/in/drea-wichman" target="_blank" rel="noopener" class="modal__btn">LinkedIn</a>
      <a href="https://github.com/drea-wichman" target="_blank" rel="noopener" class="modal__btn">GitHub</a>
    </div>
  </div>
</div>

<style>
  .modal-backdrop {
    display: none !important;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(13, 32, 24, 0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  
  .modal-backdrop.is-open {
    display: flex !important;
  }
  
  .modal {
    position: relative;
    background: var(--color-light);
    width: 100%;
    max-width: 320px;
    padding: 32px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  
  .modal__logo {
    width: 56px;
    height: 32px;
    color: var(--color-dark);
    margin-bottom: 4px;
  }
  
  .modal__logo svg {
    width: 100%;
    height: 100%;
  }
  
  .modal__text {
    font-size: 11px;
    line-height: 1.5;
    color: var(--text-muted-on-light);
    margin: 0;
  }
  
  .modal__buttons {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 8px;
    width: 100%;
    align-items: center;
  }
  
  .modal__btn {
    display: inline-block;
    padding: 6px 20px;
    border: 1px solid var(--color-emerald);
    color: var(--color-emerald);
    font-size: 10px;
    font-weight: 600;
    background: transparent;
    cursor: pointer;
    min-width: 110px;
    text-align: center;
    text-decoration: none;
    margin-top: 8px;
  }
  
  .modal__btn:hover {
    background: var(--color-emerald);
    color: var(--text-on-dark);
  }
  
  .modal__buttons .modal__btn {
    margin-top: 0;
  }
  
  .modal__close {
    position: absolute;
    top: 8px;
    right: 12px;
    font-size: 18px;
    color: var(--text-muted-on-light);
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
  }
  
  .modal__close:hover {
    color: var(--color-dark);
  }
</style>

<script>
  // Welcome modal: show on first visit only
  const welcomeModal = document.getElementById('welcome-modal');
  const dismissWelcome = document.getElementById('dismiss-welcome');
  const openWelcomeBtn = document.getElementById('open-welcome-modal');
  
  if (welcomeModal && !localStorage.getItem('fenn-welcome-seen')) {
    welcomeModal.classList.add('is-open');
  }
  
  dismissWelcome?.addEventListener('click', () => {
    welcomeModal?.classList.remove('is-open');
    localStorage.setItem('fenn-welcome-seen', 'true');
  });
  
  openWelcomeBtn?.addEventListener('click', () => {
    welcomeModal?.classList.add('is-open');
  });
  
  const contactModal = document.getElementById('contact-modal');
  const openContactBtn = document.getElementById('open-contact-modal');
  const closeContactBtn = document.getElementById('close-contact');
  
  openContactBtn?.addEventListener('click', () => {
    contactModal?.classList.add('is-open');
  });
  
  closeContactBtn?.addEventListener('click', () => {
    contactModal?.classList.remove('is-open');
  });
  
  contactModal?.addEventListener('click', (e) => {
    if (e.target === contactModal) {
      contactModal.classList.remove('is-open');
    }
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      contactModal?.classList.remove('is-open');
    }
  });
</script>