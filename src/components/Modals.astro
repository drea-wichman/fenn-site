<!-- Welcome modal (shows on first visit) -->
<div class="modal-backdrop" id="welcome-modal" role="dialog" aria-modal="true" aria-labelledby="welcome-title">
  <div class="modal">
    <p class="modal__text" id="welcome-title"><strong>Welcome to Fenn.</strong></p>
    <p class="modal__text">
      We are a fictional company built as an independent GRC portfolio project. Third-party vendor names referenced throughout this site are real companies, but no affiliation or endorsement exists or is implied.
    </p>
    
    <button class="modal__btn" id="dismiss-welcome">I understand</button>
    
    <div class="modal__logo" aria-hidden="true">
      <svg viewBox="-240 -165 825 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 35 -100 Q 35 -158 80 -158 L 110 -158 L 110 -151 L 82 -151 Q 42 -151 42 -100 L 42 0 L 35 0 Z" fill="currentColor"/>
        <rect x="-235" y="-104" width="815" height="7" fill="currentColor"/>
        <rect x="80" y="-95" width="7" height="95" fill="currentColor"/>
        <rect x="80" y="-54" width="56" height="7" fill="currentColor"/>
        <rect x="80" y="-7" width="64" height="7" fill="currentColor"/>
        <path d="M 158 -80 L 165 -80 L 228 -15 L 228 -80 L 235 -80 L 235 0 L 228 0 L 165 -65 L 165 0 L 158 0 Z" fill="currentColor"/>
        <path d="M 253 -80 L 260 -80 L 323 -15 L 323 -80 L 330 -80 L 330 0 L 323 0 L 260 -65 L 260 0 L 253 0 Z" fill="currentColor"/>
      </svg>
    </div>
  </div>
</div>

<!-- Contact modal (opens when Contact us is clicked) -->
<div class="modal-backdrop" id="contact-modal" role="dialog" aria-modal="true" aria-labelledby="contact-title">
  <div class="modal">
    <button class="modal__close" id="close-contact" aria-label="Close">×</button>
    
    <p class="modal__text" id="contact-title">Fenn is fictional, but the work is real.<br />Get in touch below.</p>
    
    <div class="modal__buttons">
      <a href="mailto:hello@wichman.io" class="modal__btn">Email</a>
      <a href="https://linkedin.com/in/drea-wichman" target="_blank" rel="noopener" class="modal__btn">LinkedIn</a>
      <a href="https://github.com/drea-wichman" target="_blank" rel="noopener" class="modal__btn">GitHub</a>
    </div>
    
    <div class="modal__logo" aria-hidden="true">
      <svg viewBox="-240 -165 825 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 35 -100 Q 35 -158 80 -158 L 110 -158 L 110 -151 L 82 -151 Q 42 -151 42 -100 L 42 0 L 35 0 Z" fill="currentColor"/>
        <rect x="-235" y="-104" width="815" height="7" fill="currentColor"/>
        <rect x="80" y="-95" width="7" height="95" fill="currentColor"/>
        <rect x="80" y="-54" width="56" height="7" fill="currentColor"/>
        <rect x="80" y="-7" width="64" height="7" fill="currentColor"/>
        <path d="M 158 -80 L 165 -80 L 228 -15 L 228 -80 L 235 -80 L 235 0 L 228 0 L 165 -65 L 165 0 L 158 0 Z" fill="currentColor"/>
        <path d="M 253 -80 L 260 -80 L 323 -15 L 323 -80 L 330 -80 L 330 0 L 323 0 L 260 -65 L 260 0 L 253 0 Z" fill="currentColor"/>
      </svg>
    </div>
  </div>
</div>

<style>
  .modal-backdrop {
    display: none !important;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(13, 32, 24, 0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  
  .modal-backdrop.is-open {
    display: flex !important;
  }
  
  .modal {
    position: relative;
    background: var(--color-light);
    width: 100%;
    max-width: 360px;
    padding: 40px 32px 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }
  
  .modal__text {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-muted-on-light);
    margin: 0;
  }
  
  .modal__text strong {
    color: var(--color-dark);
    font-weight: 700;
  }
  
  .modal__buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 8px;
    width: 100%;
    align-items: center;
  }
  
.modal__btn {
    display: inline-block;
    padding: 6px 20px;
    background: var(--color-dark);
    color: var(--text-on-dark);
    border: 1px solid var(--color-dark);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    min-width: 112px;
    text-align: center;
    text-decoration: none;
    transition: background var(--transition), color var(--transition);
    margin-top: 8px;
  }
  
  .modal__btn:hover {
    background: var(--color-light);
    color: var(--color-dark);
  }
  
  .modal__buttons .modal__btn {
    margin-top: 0;
  }
  
  .modal__logo {
    width: 100px;
    height: 22px;
    color: var(--color-dark);
    margin-top: 20px;
  }
  
  .modal__logo svg {
    width: 100%;
    height: 100%;
  }
  
  .modal__close {
    position: absolute;
    top: 12px;
    right: 16px;
    font-size: 22px;
    color: var(--text-muted-on-light);
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
    background: transparent;
    border: none;
  }
  
  .modal__close:hover {
    color: var(--color-dark);
  }
</style>

<script>
  const welcomeModal = document.getElementById('welcome-modal');
  const dismissWelcome = document.getElementById('dismiss-welcome');
  const openWelcomeBtn = document.getElementById('open-welcome-modal');
  
  if (welcomeModal && !localStorage.getItem('fenn-welcome-seen-v4')) {
    welcomeModal.classList.add('is-open');
  }
  
  dismissWelcome?.addEventListener('click', () => {
    welcomeModal?.classList.remove('is-open');
    localStorage.setItem('fenn-welcome-seen-v4', 'true');
  });
  
  openWelcomeBtn?.addEventListener('click', () => {
    welcomeModal?.classList.add('is-open');
  });
  
  const contactModal = document.getElementById('contact-modal');
  const openContactBtn = document.getElementById('open-contact-modal');
  const closeContactBtn = document.getElementById('close-contact');
  
  openContactBtn?.addEventListener('click', () => {
    contactModal?.classList.add('is-open');
  });
  
  closeContactBtn?.addEventListener('click', () => {
    contactModal?.classList.remove('is-open');
  });
  
  contactModal?.addEventListener('click', (e) => {
    if (e.target === contactModal) {
      contactModal.classList.remove('is-open');
    }
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      contactModal?.classList.remove('is-open');
    }
  });
</script>