<!-- Welcome modal (shows on first visit) -->
<div class="modal-backdrop" id="welcome-modal" role="dialog" aria-modal="true" aria-label="Welcome">
  <div class="modal">
    <p class="modal__eyebrow">Welcome</p>
    <p class="modal__body">
      Fenn is a fictional company built as an independent GRC portfolio project. Vendor names throughout this site are real, but no affiliation or endorsement is implied.
    </p>

    <button class="modal__btn" id="dismiss-welcome">I understand</button>

    <div class="modal__logo" aria-hidden="true">
      <img src="/logo-final-dark.png" alt="" width="1009" height="292" />
    </div>
  </div>
</div>

<!-- Contact modal (opens when Contact us is clicked) -->
<div class="modal-backdrop" id="contact-modal" role="dialog" aria-modal="true" aria-labelledby="contact-title">
  <div class="modal">
    <button class="modal__close" id="close-contact" aria-label="Close">&times;</button>

    <p class="modal__eyebrow">Contact</p>
    <h2 class="modal__title" id="contact-title">Fenn is fictional,<br />but the work is real.</h2>

    <div class="modal__buttons">
      <a href="mailto:hello@wichman.io" class="modal__btn">Email</a>
      <a href="https://linkedin.com/in/drea-wichman" target="_blank" rel="noopener" class="modal__btn">LinkedIn</a>
      <a href="https://github.com/drea-wichman" target="_blank" rel="noopener" class="modal__btn">GitHub</a>
    </div>

    <div class="modal__logo" aria-hidden="true">
      <img src="/logo-final-dark.png" alt="" width="1009" height="292" />
    </div>
  </div>
</div>

<style>
  .modal-backdrop {
    display: none !important;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(26, 34, 24, 0.92);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .modal-backdrop.is-open {
    display: flex !important;
  }

  .modal {
    position: relative;
    background: var(--color-paper);
    width: 100%;
    max-width: 340px;
    padding: 20px 24px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
  }

  .modal__eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-steel);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0;
  }

  .modal__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.18;
    color: var(--color-ink);
    margin: 0;
  }

  .modal__body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-slate);
    line-height: 1.6;
    margin: 0;
    max-width: 320px;
  }

  .modal__buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 0;
    width: 100%;
    align-items: center;
  }

  .modal__btn {
    display: inline-block;
    padding: 10px 24px;
    background: #0A0A0A;
    color: var(--color-paper);
    border: 1px solid #0A0A0A;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    min-width: 132px;
    text-align: center;
    text-decoration: none;
    transition: background var(--transition), color var(--transition), border-color var(--transition);
    margin-top: 0;
  }

  .modal__btn:hover {
    background: transparent;
    color: #0A0A0A;
    border-color: #0A0A0A;
  }

  .modal__buttons .modal__btn {
    margin-top: 0;
  }

  .modal__logo {
    margin-top: 24px;
  }

  .modal__logo img {
    display: block;
    height: 24px;
    width: auto;
  }

  .modal__close {
    position: absolute;
    top: 6px;
    right: 8px;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--color-ink);
    cursor: pointer;
    padding: 2px 6px;
    line-height: 1;
    background: transparent;
    border: none;
    transition: color var(--transition);
  }

  .modal__close:hover {
    color: var(--color-rust);
  }

  #contact-modal .modal {
    max-width: 300px;
  }

  #contact-modal .modal__buttons {
    max-width: 65%;
  }

</style>

<script>
  const welcomeModal = document.getElementById('welcome-modal');
  const dismissWelcome = document.getElementById('dismiss-welcome');
  const openWelcomeBtn = document.getElementById('open-welcome-modal');

  if (welcomeModal && !localStorage.getItem('fenn-welcome-seen-v4')) {
    welcomeModal.classList.add('is-open');
  }

  dismissWelcome?.addEventListener('click', () => {
    welcomeModal?.classList.remove('is-open');
    localStorage.setItem('fenn-welcome-seen-v4', 'true');
  });

  openWelcomeBtn?.addEventListener('click', () => {
    welcomeModal?.classList.add('is-open');
  });

  const contactModal = document.getElementById('contact-modal');
  const openContactBtn = document.getElementById('open-contact-modal');
  const closeContactBtn = document.getElementById('close-contact');

  openContactBtn?.addEventListener('click', () => {
    contactModal?.classList.add('is-open');
  });

  closeContactBtn?.addEventListener('click', () => {
    contactModal?.classList.remove('is-open');
  });

  contactModal?.addEventListener('click', (e) => {
    if (e.target === contactModal) {
      contactModal.classList.remove('is-open');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      contactModal?.classList.remove('is-open');
    }
  });
</script>
