---
const { currentPage = '' } = Astro.props;
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Fenn">
      <svg viewBox="-20 -165 280 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 23 -100 Q 23 -160 60 -160 L 85 -160 L 85 -150 L 62 -150 Q 33 -150 33 -100 L 33 0 L 23 0 Z" fill="currentColor"/>
        <rect x="-17" y="-105" width="286" height="10" fill="currentColor"/>
        <rect x="50" y="-95" width="10" height="95" fill="currentColor"/>
        <rect x="50" y="-55" width="42" height="10" fill="currentColor"/>
        <rect x="50" y="-10" width="48" height="10" fill="currentColor"/>
        <path d="M 115 -80 L 125 -80 L 165 -15 L 165 -80 L 175 -80 L 175 0 L 165 0 L 125 -65 L 125 0 L 115 0 Z" fill="currentColor"/>
        <path d="M 192 -80 L 202 -80 L 242 -15 L 242 -80 L 252 -80 L 252 0 L 242 0 L 202 -65 L 202 0 L 192 0 Z" fill="currentColor"/>
      </svg>
    </a>
    
<nav class="header__nav">
      <a href="/policies" class={currentPage === 'policies' ? 'header__link header__link--active' : 'header__link'}>Policies</a>
      <a href="/behind-fenn" class={currentPage === 'behind-fenn' ? 'header__link header__link--active' : 'header__link'}>Behind Fenn</a>
      <button class="btn-outline-white header__cta" id="open-contact-modal">Contact us</button>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--color-dark);
    padding: 16px 0;
  }
  
  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .header__logo {
    display: block;
    color: var(--text-on-dark);
    width: 168px;
    height: 96px;
    transition: opacity var(--transition);
  }
  
  .header__logo:hover {
    opacity: 0.85;
  }
  
  .header__logo svg {
    width: 100%;
    height: 100%;
  }
  
  .header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  
  .header__link {
    color: var(--text-on-dark);
    font-size: 13px;
    font-weight: 500;
    transition: color var(--transition);
  }
  
  .header__link:hover {
    color: var(--color-emerald);
  }
  
  .header__link--active {
    color: var(--color-emerald);
    font-weight: 700;
  }
  
  .header__cta {
    cursor: pointer;
  }
  
  @media (max-width: 768px) {
    .header__logo {
      width: 112px;
      height: 64px;
    }
    
    .header__nav {
      gap: 16px;
    }
    
    .header__link {
      font-size: 12px;
    }
  }
</style>