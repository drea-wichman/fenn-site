---
const { currentPage = '' } = Astro.props;
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo">
      <img src="/logo-final.png" alt="Fenn" width="1009" height="292" />
    </a>

    <nav class="header__nav">
      <a href="/trust-center" class={currentPage === 'trust-center' ? 'header__link header__link--active' : 'header__link'}>Trust Center</a>
      <a href="/behind-fenn" class={currentPage === 'behind-fenn' ? 'header__link header__link--active' : 'header__link'}>Behind Fenn</a>
      <button class="btn-outline-white header__cta" id="open-contact-modal">Contact us</button>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--color-ink);
    padding: 16px 0;
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header__logo {
    display: block;
    transition: opacity var(--transition);
    /* Align with hero headline left edge: clamps to 0 below 1280vw, -40 above 1360vw. */
    margin-left: min(0px, max(-40px, calc(640px - 50vw)));
  }

  .header__logo:hover {
    opacity: 0.85;
  }

  .header__logo img {
    display: block;
    height: 72px;
    width: auto;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header__link {
    font-family: var(--font-mono);
    color: var(--color-paper);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color var(--transition);
  }

  .header__link:hover {
    color: var(--color-clay);
  }

  .header__link--active {
    color: var(--color-steel-light);
    font-weight: 500;
  }

  .header__cta {
    cursor: pointer;
  }

  @media (max-width: 768px) {
    .header__logo img {
      height: 48px;
    }

    .header__nav {
      gap: 16px;
    }

    .header__link {
      font-size: 10px;
    }
  }
</style>
