---
const { currentPage = '' } = Astro.props;
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Fenn">
      <svg viewBox="-240 -165 825 170" xmlns="http://www.w3.org/2000/svg">
        <path d="M 35 -100 Q 35 -158 80 -158 L 110 -158 L 110 -151 L 82 -151 Q 42 -151 42 -100 L 42 0 L 35 0 Z" fill="currentColor"/>
        <rect x="-235" y="-104" width="815" height="7" fill="currentColor"/>
        <rect x="80" y="-95" width="7" height="95" fill="currentColor"/>
        <rect x="80" y="-54" width="56" height="7" fill="currentColor"/>
        <rect x="80" y="-7" width="64" height="7" fill="currentColor"/>
        <path d="M 158 -80 L 165 -80 L 228 -15 L 228 -80 L 235 -80 L 235 0 L 228 0 L 165 -65 L 165 0 L 158 0 Z" fill="currentColor"/>
        <path d="M 253 -80 L 260 -80 L 323 -15 L 323 -80 L 330 -80 L 330 0 L 323 0 L 260 -65 L 260 0 L 253 0 Z" fill="currentColor"/>
      </svg>
    </a>
    
<nav class="header__nav">
<a href="/trust-center" class={currentPage === 'trust-center' ? 'header__link header__link--active' : 'header__link'}>Trust Center</a>      <a href="/behind-fenn" class={currentPage === 'behind-fenn' ? 'header__link header__link--active' : 'header__link'}>Behind Fenn</a>
      <button class="btn-outline-white header__cta" id="open-contact-modal">Contact us</button>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--color-dark);
    padding: 16px 0;
  }
  
  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
.header__logo {
    display: block;
    color: var(--text-on-dark);
    width: 240px;
    height: 100px;
    transition: opacity var(--transition);
  }
  
  .header__logo:hover {
    opacity: 0.85;
  }
  
  .header__logo svg {
    width: 100%;
    height: 100%;
  }
  
  .header__nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  
  .header__link {
    color: var(--text-on-dark);
    font-size: 13px;
    font-weight: 500;
    transition: color var(--transition);
  }
  
  .header__link:hover {
    color: var(--color-emerald);
  }
  
  .header__link--active {
    color: var(--color-emerald);
    font-weight: 700;
  }
  
  .header__cta {
    cursor: pointer;
  }
  
  @media (max-width: 768px) {
    .header__logo {
      width: 112px;
      height: 64px;
    }
    
    .header__nav {
      gap: 16px;
    }
    
    .header__link {
      font-size: 12px;
    }
  }
</style>