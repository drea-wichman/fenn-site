---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Fenn Agritech — Your land. Your data. Your decision."
  description="Crop and field management software built for UK farms. Compliance records, field operations, sustainability reporting in one app."
  currentPage="home"
  bodyClass="page-landing"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__content">
      <h1 class="hero__headline">
        Your land.<br />
        Your data.<br />
        <em class="hero__headline-em">Your decision.</em>
      </h1>
      <p class="hero__subhead">Built for the people who feed Britain.</p>
    </div>
    <div class="hero__photo">
      <img src="/images/hero-dartmoor.jpg" alt="Rolling green farmland in Devon, England, divided by traditional hedgerows" />
      <div class="hero__grain" aria-hidden="true"></div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="trust-strip">
    <div class="trust-strip__inner" data-fade>
      <div class="trust-cert">
        <p class="trust-cert__label">Cyber Essentials Plus</p>
        <p class="trust-cert__status">Aligned to the framework.</p>
      </div>
      <div class="trust-cert__rule" aria-hidden="true"></div>
      <div class="trust-cert">
        <p class="trust-cert__label">ISO/IEC 27001:2022</p>
        <p class="trust-cert__status">Aligned to the standard.</p>
      </div>
      <div class="trust-cert__rule" aria-hidden="true"></div>
      <div class="trust-cert">
        <p class="trust-cert__label">UK GDPR</p>
        <p class="trust-cert__status">Aligned to data protection law.</p>
      </div>
      <div class="trust-cert__rule" aria-hidden="true"></div>
      <div class="trust-cert">
        <p class="trust-cert__label">NCSC CAF</p>
        <p class="trust-cert__status">Mapped to security objectives.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="container">
      <div class="how-it-works__header" data-fade>
        <p class="section-label">How it works</p>
        <h2 class="section-headline">The whole farm on one screen.</h2>
      </div>

      <div class="how-it-works__steps">
        <article class="step">
          <span class="step__num">01</span>
          <h3 class="step__name">Connect</h3>
          <div class="step__body">
            <p>Link your existing equipment, sensors, and accounting to Fenn.</p>
            <p>Opt out of any features you don't want, for your privacy.</p>
          </div>
          <ul class="step__features">
            <li>
              <p class="feature__title">Equipment</p>
              <p class="feature__items">John Deere &middot; Case IH &middot; New Holland</p>
            </li>
            <li>
              <p class="feature__title">Sensors</p>
              <p class="feature__items">Soil Scout &middot; Sentek &middot; Davis</p>
            </li>
            <li>
              <p class="feature__title">Accounting</p>
              <p class="feature__items">Xero &middot; QuickBooks &middot; Sage</p>
            </li>
          </ul>
        </article>

        <article class="step">
          <span class="step__num">02</span>
          <h3 class="step__name">Track</h3>
          <div class="step__body">
            <p>Choose your sources and start capturing data.</p>
            <p>Fenn keeps your data updated in real time, on every device.</p>
          </div>
          <ul class="step__features">
            <li>
              <p class="feature__title">Field Operations</p>
              <p class="feature__items">ISOBUS Equipment &middot; GPS Field Mapping &middot; Drone Surveys &middot; Spray Records</p>
            </li>
            <li>
              <p class="feature__title">Environment</p>
              <p class="feature__items">Weather APIs &middot; Soil Sensors</p>
            </li>
            <li>
              <p class="feature__title">Finances</p>
              <p class="feature__items">Accounting Sync &middot; Receipt Capture</p>
            </li>
            <li>
              <p class="feature__title">Inventory</p>
              <p class="feature__items">Stock Auto-deduct &middot; Invoice Scan &middot; Batch Numbers</p>
            </li>
            <li>
              <p class="feature__title">Team Accounts</p>
              <p class="feature__items">Assign Jobs &middot; Share Photos &middot; Set Permissions</p>
            </li>
          </ul>
          <p class="step__footnote">Manual entry available for each category.</p>
        </article>

        <article class="step">
          <span class="step__num">03</span>
          <h3 class="step__name">Report</h3>
          <div class="step__body">
            <p>Fenn generates the records you need in minutes.</p>
            <p>Download, export, or share your records in any format, anytime.</p>
          </div>
          <ul class="step__features">
            <li>
              <p class="feature__title">Defra Schemes</p>
              <p class="feature__items">SFI &middot; Countryside Stewardship</p>
            </li>
            <li>
              <p class="feature__title">Assurance Audits</p>
              <p class="feature__items">Red Tractor &middot; Soil Association Organic</p>
            </li>
            <li>
              <p class="feature__title">Tax Records</p>
              <p class="feature__items">Making Tax Digital &middot; Receipts and Margins</p>
            </li>
            <li>
              <p class="feature__title">Sustainability</p>
              <p class="feature__items">Emissions &middot; Biodiversity</p>
            </li>
            <li>
              <p class="feature__title">Yield Forecasts</p>
              <p class="feature__items">Live Updates &middot; Per Field</p>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- PRIVACY, PROVEN -->
  <section class="privacy-proven">
    <div class="container">
      <div data-fade>
        <p class="section-label section-label--on-dark">Privacy, proven</p>
        <h2 class="section-headline section-headline--light">Six commitments.</h2>
      </div>

      <div class="privacy-proven__grid">
        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -20 30 35" xmlns="http://www.w3.org/2000/svg">
              <rect x="-12" y="-2" width="24" height="18" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M -7 -2 L -7 -10 Q -7 -16 0 -16 Q 7 -16 7 -10 L 7 -2" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Encryption every step of the way.</h3>
          <p class="commitment__body">Your records are encrypted before leaving your phone and stay locked through our servers. The keys are yours alone.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -10 30 20" xmlns="http://www.w3.org/2000/svg">
              <circle cx="-10" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-4" y1="0" x2="14" y2="0" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="0" x2="8" y2="5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="13" y1="0" x2="13" y2="4" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Built for banks. Now for your farm.</h3>
          <p class="commitment__body">Cryptographic key management, made for you by the engineer who built it for a UK challenger bank. Serious work, serious protection.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-18 -12 36 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M -14 0 Q -7 -8 0 -8 Q 7 -8 14 0 Q 7 8 0 8 Q -7 8 -14 0 Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="0" cy="0" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Access any audits, anytime.</h3>
          <p class="commitment__body">Every interaction with your data is recorded and available to you in real time. Because we believe trust is built on transparency.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -12 30 24" xmlns="http://www.w3.org/2000/svg">
              <circle cx="-10" cy="-6" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="10" cy="-6" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="0" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-8" y1="-4" x2="-2" y2="6" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="-4" x2="2" y2="6" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-7" y1="-6" x2="7" y2="-6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">AI without the audience.</h3>
          <p class="commitment__body">Our forecasting models don't train on your data. Opt in or out of our AI analytics, any time. Your data stays yours, always.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -15 30 30" xmlns="http://www.w3.org/2000/svg">
              <path d="M -10 -10 L 10 -10 L 10 2 Q 10 8 0 12 Q -10 8 -10 2 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
              <polyline points="-4,0 -1,4 5,-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="commitment__title">Your data isn't for sale.</h3>
          <p class="commitment__body">We never sell, rent, or share your data for marketing or AI training. Sub-processors are listed in full and serve operational needs only.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-18 -12 36 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M -8 -10 L -14 -10 L -14 10 L -8 10" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-6" y1="0" x2="14" y2="0" stroke="currentColor" stroke-width="1.5"/>
              <polyline points="8,-5 14,0 8,5" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Leave with everything you brought.</h3>
          <p class="commitment__body">Export or port any field record at any time. Close your account and we'll delete everything within 30 days, no questions asked.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS COUNT-UP -->
  <section class="stats-count" data-stats data-fade aria-label="Fenn by the numbers">
    <div class="container">
      <div class="stats-count__grid">
        <div class="stat">
          <p class="stat__num" data-stat-target="1000+">0</p>
          <p class="stat__label">farms served across the UK</p>
        </div>
        <div class="stat">
          <p class="stat__num" data-stat-target="47">0</p>
          <p class="stat__label">compliance schemes supported</p>
        </div>
        <div class="stat">
          <p class="stat__num" data-stat-target="30">0</p>
          <p class="stat__label">days to delete on cancel</p>
        </div>
        <div class="stat stat--zero">
          <p class="stat__num" data-stat-target="0" data-stat-start="100000">100,000</p>
          <p class="stat__label">records kept on our servers</p>
        </div>
      </div>
    </div>
  </section>

  <!-- THE APP -->
  <section class="app-section">
    <img class="app-section__image" src="/images/cab.jpg" alt="Farmer in a tractor cab at sunset" />
    <div class="app-section__panel" data-fade>
      <p class="section-label app-section__eyebrow">The app</p>
      <h2 class="app-section__headline">Wherever work takes you.</h2>
      <p class="app-section__subtitle">From home to harvest.</p>
      <div class="app-section__icon" aria-hidden="true">
        <img src="/logo-final.png" alt="" />
      </div>
      <dl class="app-section__platforms">
        <dt>Available on</dt>
        <dd>iOS &middot; Android &middot; macOS &middot; Windows</dd>
        <dt>In-cab</dt>
        <dd>John Deere &middot; Case IH &middot; AGCO &middot; CLAAS</dd>
      </dl>
    </div>
  </section>

  <!-- OUR POLICIES -->
  <section class="policies">
    <div class="container">
      <div data-fade>
        <p class="section-label section-label--on-dark">Policies</p>
        <h2 class="section-headline section-headline--light">Upfront. In writing.</h2>
      </div>

      <div class="policies__grid">
        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Information Security</h3>
          <p class="policy-card__desc">How we protect customer data, end to end.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document</a>
        </div>

        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Access Control</h3>
          <p class="policy-card__desc">Who can access what, when, and how.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document</a>
        </div>

        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Incident Response</h3>
          <p class="policy-card__desc">How we respond when things go wrong.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document</a>
        </div>
      </div>

      <a href="/trust-center" class="btn-outline-white policies__cta">Visit Trust Center</a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cta">
    <div class="container" data-fade>
      <p class="section-label">Begin</p>
      <h2 class="cta__headline">Every farm is different.<br />Tell us about yours.</h2>
      <button class="btn-dark cta__btn" id="open-contact-modal-cta">Try Fenn</button>
    </div>
  </section>
</Layout>

<script>
  document.getElementById('open-contact-modal-cta')?.addEventListener('click', () => {
    document.getElementById('contact-modal')?.classList.add('is-open');
  });
</script>

<style>
  /* ========================================================================
     HERO — ink background, Archivo 800 headline, paper photo with hairline
     ======================================================================== */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--color-ink);
    min-height: 600px;
    align-items: stretch;
    position: relative;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding: 96px var(--gutter);
    max-width: 680px;
    justify-self: end;
    width: 100%;
    align-self: center;
  }
  .hero__headline {
    font-family: var(--font-display);
    font-size: 76px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: var(--color-paper);
    margin-bottom: 28px;
  }
  .hero__headline-em {
    font-style: normal;
    font-weight: 800;
    color: var(--color-brass);
  }
  .hero__subhead {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 17px;
    font-weight: 500;
    color: var(--color-stone);
    line-height: 1.5;
    letter-spacing: 0.01em;
    margin-left: 3px;
  }
  .hero__photo {
    position: relative;
    overflow: hidden;
    min-height: 600px;
    border-left: 1px solid var(--divider-dark);
  }
  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    filter: saturate(0.85) brightness(0.95);
    transform-origin: center;
    will-change: transform;
    animation: hero-kenburns 16s ease-in-out infinite alternate;
  }
  @keyframes hero-kenburns {
    0%   { transform: scale(1.16) translate3d(-8%, -4%, 0); }
    100% { transform: scale(1.20) translate3d( 8%,  4%, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__photo img { animation: none; }
  }
  /* 35mm-style film grain — stepped translate so it reads analog, not digital.
     Sits inside the photo only; hero text is in a separate grid column. */
  .hero__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: url('/film-grain.png') repeat;
    background-size: 240px 240px;
    opacity: 0.12;
    mix-blend-mode: overlay;
    animation: hero-grain 0.48s steps(8, jump-none) infinite;
    will-change: transform;
    z-index: 1;
  }
  @keyframes hero-grain {
    0%, 100% { transform: translate3d(0, 0, 0); }
    12.5%    { transform: translate3d(-2%, -1%, 0); }
    25%      { transform: translate3d(3%, -2%, 0); }
    37.5%    { transform: translate3d(-1%, 2%, 0); }
    50%      { transform: translate3d(2%, 1%, 0); }
    62.5%    { transform: translate3d(-3%, -2%, 0); }
    75%      { transform: translate3d(1%, 3%, 0); }
    87.5%    { transform: translate3d(-2%, 1%, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__grain { animation: none; }
  }
  .hero__caption {
    position: absolute;
    bottom: 20px;
    right: 24px;
    font-family: var(--font-mono);
    color: var(--color-paper);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  /* ========================================================================
     TRUST STRIP — vellum band with mono labels and italic statuses
     ======================================================================== */
  .trust-strip {
    background: var(--color-ink);
    padding: 32px 0;
  }
  .trust-strip__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 32px;
  }
  .trust-cert {
    text-align: center;
  }
  .trust-cert__label {
    font-family: var(--font-mono);
    color: var(--color-steel-light);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .trust-cert__status {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 500;
    color: var(--color-stone);
    font-size: 12px;
    line-height: 1.4;
  }
  .trust-cert__rule {
    width: 1px;
    height: 48px;
    background: color-mix(in srgb, var(--color-stone) 35%, transparent);
  }

  /* ========================================================================
     HOW IT WORKS — paper background, large step numerals
     ======================================================================== */
  .how-it-works {
    background: var(--color-paper);
    padding: 112px 0 128px;
  }
  .how-it-works__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 16px;
  }
  .how-it-works__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto auto auto auto;
    column-gap: 48px;
    row-gap: 0;
    align-items: start;
  }
  .step {
    display: grid;
    grid-template-rows: subgrid;
    grid-row: span 5;
    text-align: left;
  }
  .step__num {
    display: block;
    font-family: var(--font-display);
    font-size: 72px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-slate);
    margin-bottom: 8px;
  }
  .step__name {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .step__body > p {
    font-family: var(--font-display);
    font-size: 16px;
    color: var(--color-slate);
    line-height: 1.55;
    margin: 0 0 8px;
  }
  .step__features {
    list-style: none;
    padding: 24px 0 0;
    margin: 10px 0 0;
    border-top: 1px solid var(--color-stone);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .step__features li {
    text-align: left;
  }
  .feature__title {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 4px;
  }
  .feature__items {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--color-ink);
    line-height: 1.5;
    margin: 0;
  }
  .step__footnote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    color: var(--color-slate);
    line-height: 1.5;
    margin: 16px 0 0;
  }

  /* ========================================================================
     PRIVACY PROVEN — ink background, the page's dark pull-quote
     ======================================================================== */
  .privacy-proven {
    background: var(--color-ink);
    padding: 112px 0 128px;
  }
  .section-label--on-dark {
    color: var(--color-steel-light);
  }
  .section-headline--light {
    color: var(--color-paper);
  }
  .privacy-proven__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 72px 56px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .commitment {
    text-align: center;
  }
  .commitment__icon {
    color: var(--color-rust);
    width: 22px;
    height: 22px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .commitment__icon svg {
    width: 100%;
    height: 100%;
  }
  .commitment__title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 500;
    color: var(--color-paper);
    margin-bottom: 14px;
