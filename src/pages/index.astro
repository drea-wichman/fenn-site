---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Fenn Agritech — Your land. Your data. Your decision."
  description="Crop and field management software built for UK farms. Compliance records, field operations, sustainability reporting in one app."
  currentPage="home"
  bodyClass="page-landing"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__content">
      <h1 class="hero__headline">
        Your land.<br />
        Your data.<br />
        <em class="hero__headline-em">Your decision.</em>
      </h1>
      <p class="hero__subhead">Built for the people who feed Britain.</p>
    </div>
    <div class="hero__photo">
      <img src="/images/hero-dartmoor.jpg" alt="Rolling green farmland in Devon, England, divided by traditional hedgerows" />
      <p class="hero__caption">Dartmoor &middot; Devon</p>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="trust-strip">
    <div class="trust-strip__inner">
      <div class="trust-cert">
        <p class="trust-cert__label">Cyber Essentials Plus</p>
        <p class="trust-cert__status">Aligned to the framework.</p>
      </div>
      <div class="trust-cert__rule" aria-hidden="true"></div>
      <div class="trust-cert">
        <p class="trust-cert__label">ISO 27001:2022</p>
        <p class="trust-cert__status">Documentation aligned to the standard.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="container">
      <p class="section-label">How it works</p>
      <h2 class="section-headline">The whole farm on one screen.</h2>

      <div class="step">
        <div class="step__heading">
          <span class="step__num">01</span>
          <span class="step__name">Connect</span>
        </div>
        <div class="step__body">
          <p>Link your existing equipment, sensors, and accounting (Xero, QuickBooks, Sage, and more) to Fenn.</p>
          <p>Opt out of any features you don't want, for your privacy.</p>
        </div>
      </div>

      <div class="step">
        <div class="step__heading">
          <span class="step__num">02</span>
          <span class="step__name">Track</span>
        </div>
        <div class="step__body">
          <p>Choose your sources and start capturing data.</p>
          <p>Fenn keeps your data updated in real time, on every device.</p>
        </div>

        <div class="cluster-grid">
          <div class="cluster">
            <p class="cluster__title">Field Operations</p>
            <p class="cluster__item">ISOBUS Equipment</p>
            <p class="cluster__item">GPS Field Mapping</p>
            <p class="cluster__item">Drone Surveys</p>
            <p class="cluster__item">Spray Records</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Environment</p>
            <p class="cluster__item">Weather APIs</p>
            <p class="cluster__item">Soil Sensors</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Finances</p>
            <p class="cluster__item">Accounting Sync</p>
            <p class="cluster__item">Invoice Scan</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Inventory</p>
            <p class="cluster__item">Auto On Apply</p>
            <p class="cluster__item">Invoice Scan</p>
            <p class="cluster__item">Batch Numbers</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Team Accounts</p>
            <p class="cluster__item">Assign Jobs</p>
            <p class="cluster__item">Share Photos</p>
            <p class="cluster__item">Set Permissions</p>
          </div>
          <p class="cluster-grid__note">Manual entry available for each category.</p>
        </div>
      </div>

      <div class="step">
        <div class="step__heading">
          <span class="step__num">03</span>
          <span class="step__name">Report</span>
        </div>
        <div class="step__body">
          <p>Fenn generates the records you need in minutes.</p>
          <p>Download, export, or share your records in any format, anytime.</p>
        </div>

        <div class="cluster-grid">
          <div class="cluster">
            <p class="cluster__title">Defra Schemes</p>
            <p class="cluster__item">SFI</p>
            <p class="cluster__item">Countryside Stewardship</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Assurance Audits</p>
            <p class="cluster__item">Red Tractor</p>
            <p class="cluster__item">Soil Association Organic</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Tax Records</p>
            <p class="cluster__item">Making Tax Digital</p>
            <p class="cluster__item">Receipts And Margins</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Sustainability</p>
            <p class="cluster__item">Emissions</p>
            <p class="cluster__item">Biodiversity</p>
          </div>
          <div class="cluster">
            <p class="cluster__title">Yield Forecasts</p>
            <p class="cluster__item">Live Updates</p>
            <p class="cluster__item">Per Field</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRIVACY, PROVEN -->
  <section class="privacy-proven">
    <div class="container">
      <p class="section-label section-label--on-dark">Privacy, proven</p>
      <h2 class="section-headline section-headline--light">Six commitments.</h2>

      <div class="privacy-proven__grid">
        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -20 30 35" xmlns="http://www.w3.org/2000/svg">
              <rect x="-12" y="-2" width="24" height="18" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <path d="M -7 -2 L -7 -10 Q -7 -16 0 -16 Q 7 -16 7 -10 L 7 -2" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Encryption every step of the way.</h3>
          <p class="commitment__body">Your records are encrypted before leaving your phone and stay locked through our servers. The keys are yours alone.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -10 30 20" xmlns="http://www.w3.org/2000/svg">
              <circle cx="-10" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-4" y1="0" x2="14" y2="0" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="0" x2="8" y2="5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="13" y1="0" x2="13" y2="4" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Built for banks. Now for your farm.</h3>
          <p class="commitment__body">Bank-grade cryptographic key management, made for you by the engineer who built it for a UK challenger bank. Serious work, serious protection.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-18 -12 36 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M -14 0 Q -7 -8 0 -8 Q 7 -8 14 0 Q 7 8 0 8 Q -7 8 -14 0 Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="0" cy="0" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Access any audits, anytime.</h3>
          <p class="commitment__body">Every interaction with your data is recorded and available to you in real time. Because we believe trust is built on transparency.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -12 30 24" xmlns="http://www.w3.org/2000/svg">
              <circle cx="-10" cy="-6" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="10" cy="-6" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="0" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-8" y1="-4" x2="-2" y2="6" stroke="currentColor" stroke-width="1.5"/>
              <line x1="8" y1="-4" x2="2" y2="6" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-7" y1="-6" x2="7" y2="-6" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">AI without the audience.</h3>
          <p class="commitment__body">Our forecasting models don't train on your data. Opt in or out of our AI analytics, any time.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-15 -15 30 30" xmlns="http://www.w3.org/2000/svg">
              <rect x="-10" y="-12" width="20" height="24" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-5" y1="-5" x2="5" y2="-5" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-5" y1="0" x2="5" y2="0" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-5" y1="5" x2="2" y2="5" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Less paperwork. More farming.</h3>
          <p class="commitment__body">Field operations, compliance forms, and sustainability reporting all in one app, generated with one click.</p>
        </div>

        <div class="commitment">
          <div class="commitment__icon">
            <svg viewBox="-18 -12 36 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M -8 -10 L -14 -10 L -14 10 L -8 10" fill="none" stroke="currentColor" stroke-width="1.5"/>
              <line x1="-6" y1="0" x2="14" y2="0" stroke="currentColor" stroke-width="1.5"/>
              <polyline points="8,-5 14,0 8,5" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3 class="commitment__title">Leave with everything you brought.</h3>
          <p class="commitment__body">Export or port any field record at any time. Close your account and we delete everything within 30 days.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- IMAGE BREAK -->
  <section class="image-break">
    <img src="/images/cab.jpg" alt="Farmer in a tractor cab at sunset" />
  </section>

  <!-- OUR POLICIES -->
  <section class="policies">
    <div class="container">
      <p class="section-label">Policies</p>
      <h2 class="section-headline">Upfront. In writing.</h2>

      <div class="policies__grid">
        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Information Security</h3>
          <p class="policy-card__desc">How we protect customer data, end to end.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document &rarr;</a>
        </div>

        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Access Control</h3>
          <p class="policy-card__desc">Who can access what, why, and how we audit it.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document &rarr;</a>
        </div>

        <div class="policy-card">
          <div class="policy-card__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
              <path d="M4 2h12l4 4v16H4z"/>
              <path d="M16 2v4h4"/>
              <line x1="7" y1="10" x2="17" y2="10"/>
              <line x1="7" y1="14" x2="17" y2="14"/>
              <line x1="7" y1="18" x2="14" y2="18"/>
            </svg>
          </div>
          <h3 class="policy-card__title">Incident Response</h3>
          <p class="policy-card__desc">How we respond when something goes wrong.</p>
          <a class="policy-card__link" href="/policies/trust-center">View document &rarr;</a>
        </div>
      </div>

      <a href="/trust-center" class="btn-dark policies__cta">Visit Trust Center</a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="cta">
    <div class="container">
      <p class="section-label">Begin</p>
      <h2 class="cta__headline">Let's work together.</h2>
      <p class="cta__sub">Currently serving 1,000+ farms across England and Wales.<br />Tell us more about your operation.</p>
      <button class="btn-dark cta__btn" id="open-contact-modal-cta">Get started</button>
    </div>
  </section>
</Layout>

<script>
  document.getElementById('open-contact-modal-cta')?.addEventListener('click', () => {
    document.getElementById('contact-modal')?.classList.add('is-open');
  });
</script>

<style>
  /* ========================================================================
     HERO — ink background, Archivo 800 headline, paper photo with hairline
     ======================================================================== */
  .hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--color-ink);
    min-height: 600px;
    align-items: stretch;
  }
  .hero__content {
    padding: 96px var(--gutter);
    max-width: 680px;
    justify-self: end;
    width: 100%;
    align-self: center;
  }
  .hero__headline {
    font-family: var(--font-display);
    font-size: 76px;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.02;
    color: var(--color-paper);
    margin-bottom: 28px;
  }
  .hero__headline-em {
    font-style: normal;
    font-weight: 800;
    color: var(--color-clay);
  }
  .hero__subhead {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 17px;
    font-weight: 500;
    color: var(--color-stone);
    line-height: 1.5;
    letter-spacing: 0.01em;
  }
  .hero__photo {
    position: relative;
    min-height: 600px;
    border-left: 1px solid var(--divider-dark);
  }
  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    filter: saturate(0.85) brightness(0.95);
  }
  .hero__caption {
    position: absolute;
    bottom: 20px;
    right: 24px;
    font-family: var(--font-mono);
    color: var(--color-paper);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  }

  /* ========================================================================
     TRUST STRIP — vellum band with mono labels and italic statuses
     ======================================================================== */
  .trust-strip {
    background: var(--color-vellum);
    padding: 32px 0;
    border-top: 1px solid var(--color-stone);
    border-bottom: 1px solid var(--color-stone);
  }
  .trust-strip__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 48px;
  }
  .trust-cert {
    text-align: center;
  }
  .trust-cert__label {
    font-family: var(--font-mono);
    color: var(--color-ink);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .trust-cert__status {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 500;
    color: var(--color-slate);
    font-size: 15px;
    line-height: 1.4;
  }
  .trust-cert__rule {
    width: 1px;
    height: 48px;
    background: var(--color-stone);
  }

  /* ========================================================================
     HOW IT WORKS — paper background, large step numerals
     ======================================================================== */
  .how-it-works {
    background: var(--color-paper);
    padding: 64px 0;
  }
  .step {
    max-width: 1100px;
    margin: 32px auto 0;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 140px 1fr;
    column-gap: 32px;
    row-gap: 6px;
    align-items: start;
  }
  .step__heading {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .step__num {
    font-family: var(--font-display);
    font-size: 88px;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-steel);
  }
  .step__name {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }
  .step__body {
    grid-column: 2;
    padding-top: 18px;
  }
  .step__body p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: 4px;
    max-width: 60ch;
  }
  .cluster-grid {
    grid-column: 2;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 28px;
    margin-top: 4px;
    padding-top: 0;
  }
  .cluster {
    text-align: center;
  }
  .cluster__title {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .cluster__item {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-slate);
    line-height: 1.5;
  }
  .cluster-grid__note {
    grid-column: 1 / -1;
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 400;
    text-align: center;
    font-size: 13px;
    color: var(--color-slate);
    margin-top: 16px;
  }

  /* ========================================================================
     PRIVACY PROVEN — ink background, the page's dark pull-quote
     ======================================================================== */
  .privacy-proven {
    background: var(--color-ink);
    padding: 112px 0 128px;
  }
  .section-label--on-dark {
    color: var(--color-steel-light);
  }
  .section-headline--light {
    color: var(--color-paper);
  }
  .privacy-proven__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 72px 56px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .commitment {
    text-align: center;
  }
  .commitment__icon {
    color: var(--color-rust);
    width: 36px;
    height: 36px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .commitment__icon svg {
    width: 100%;
    height: 100%;
  }
  .commitment__title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--color-paper);
    margin-bottom: 14px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .commitment__body {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-muted-on-dark);
    line-height: 1.65;
  }


  /* ========================================================================
     POLICIES — paper background, magazine-style TOC cards
     ======================================================================== */
  .policies {
    background: var(--color-paper);
    padding: 104px 0 112px;
    text-align: center;
  }
  .policies__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1100px;
    margin: 0 auto 56px;
    border-top: 1px solid var(--color-stone);
    border-bottom: 1px solid var(--color-stone);
  }
  .policy-card {
    padding: 36px 32px 32px;
    text-align: left;
    border-left: 1px solid var(--color-stone);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .policy-card:last-child {
    border-right: 1px solid var(--color-stone);
  }
  .policy-card__icon {
    color: var(--color-ink);
    width: 28px;
    height: 28px;
    margin: 4px 0 4px;
  }
  .policy-card__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .policy-card__title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .policy-card__desc {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-slate);
    line-height: 1.55;
    margin-bottom: 12px;
  }
  .policy-card__link {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-top: auto;
    align-self: flex-start;
    text-decoration: underline;
    text-decoration-color: rgba(26, 34, 24, 0.35);
    text-underline-offset: 3px;
    transition: color var(--transition), text-decoration-color var(--transition);
  }
  .policy-card__link:hover {
    color: var(--color-slate);
    text-decoration-color: var(--color-slate);
  }
  .policies__cta {
    padding: 14px 32px;
  }

  /* ========================================================================
     FINAL CTA — vellum, quiet, centered
     ======================================================================== */
  .cta {
    background: var(--color-vellum);
    padding: 120px 0 128px;
    text-align: center;
    border-top: 1px solid var(--color-stone);
  }
  .cta__headline {
    font-family: var(--font-display);
    font-size: 64px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin-bottom: 20px;
    line-height: 1.05;
  }
  .cta__sub {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 17px;
    font-weight: 500;
    color: var(--color-slate);
    margin-bottom: 40px;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.55;
    letter-spacing: 0.01em;
  }
  .cta__btn {
    padding: 16px 36px;
  }

  /* ========================================================================
     IMAGE BREAKS — full-bleed editorial photography
     ======================================================================== */
  .image-break {
    width: 100%;
    height: 480px;
    overflow: hidden;
    background: var(--color-ink);
  }
  .image-break img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.85);
  }
  /* ========================================================================
