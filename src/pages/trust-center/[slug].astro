---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const security = await getCollection('security');
  const compliance = await getCollection('compliance');
  const privacy = await getCollection('privacy');

  return [
    ...security.map(doc => ({
      params: { slug: doc.id },
      props: { doc, collection: 'security' },
    })),
    ...compliance.map(doc => ({
      params: { slug: doc.id },
      props: { doc, collection: 'compliance' },
    })),
    ...privacy.map(doc => ({
      params: { slug: doc.id },
      props: { doc, collection: 'privacy' },
    })),
  ];
}

const { doc, collection } = Astro.props;
const { Content } = await render(doc);

const security = await getCollection('security');
const compliance = await getCollection('compliance');

const allDocs = [
  ...security.map(d => ({ ...d, section: 'Security' })),
  ...compliance.map(d => ({ ...d, section: 'Compliance' })),
].sort((a, b) => a.data.document_id.localeCompare(b.data.document_id));

const formatDate = (date) =>
  date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const frameworkSummary = (mappings) => {
  const isoCount = mappings.filter(m => m.startsWith('ISO 27001')).length;
  const others = mappings.filter(m => !m.startsWith('ISO 27001'));
  const parts = [];
  if (isoCount > 0) parts.push(`ISO 27001:2022 (${isoCount} controls)`);
  others.forEach(o => parts.push(o));
  return parts.join(', ');
};
---

<Layout
  title={`${doc.data.title} — Fenn Agritech`}
  description={doc.data.scope}
  currentPage="trust-center"
>
  <section class="doc-page">
    <div class="doc-page__inner">
      <div class="doc-nav">
        <button class="doc-nav__toggle" id="docNavToggle" aria-expanded="false">
          All documents
          <span class="doc-nav__chevron">&#9662;</span>
        </button>
        <ul class="doc-nav__list" id="docNavList">
          {allDocs.map(d => (
   <li>
              <a
                href={`/trust-center/${d.id}`}
                class={d.id === doc.id ? 'doc-nav__link doc-nav__link--active' : 'doc-nav__link'}
              >
                {d.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <article class="doc-body">
        <h1 class="doc-body__title">{doc.data.title}</h1>
        <p class="doc-body__meta">Version {doc.data.version} · Updated {formatDate(doc.data.last_reviewed)}</p>
      <p class="doc-body__meta doc-body__meta--github">
          <a
            href={`https://github.com/drea-wichman/fenn/blob/main/${doc.id}.md`}
            target="_blank"
            rel="noopener"
            class="doc-body__github"
          >
            View on GitHub →
          </a>
        </p>

        <dl class="doc-metadata">
          <div class="doc-metadata__row">
            <dt>Document ID</dt>
            <dd>{doc.data.document_id}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Owner</dt>
            <dd>{doc.data.owner}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Approver</dt>
            <dd>{doc.data.approver}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Effective</dt>
            <dd>{formatDate(doc.data.effective_date)}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Next review</dt>
            <dd>{formatDate(doc.data.next_review)}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Scope</dt>
            <dd>{doc.data.scope}</dd>
          </div>
          <div class="doc-metadata__row">
            <dt>Framework mapping</dt>
            <dd>{frameworkSummary(doc.data.framework_mapping)}</dd>
          </div>
        </dl>

        <div class="doc-body__content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</Layout>

<script>
  const toggle = document.getElementById('docNavToggle');
  const list = document.getElementById('docNavList');
  if (toggle && list) {
    toggle.addEventListener('click', () => {
      const open = list.classList.toggle('doc-nav__list--open');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target) && !list.contains(e.target)) {
        list.classList.remove('doc-nav__list--open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

<style>
  .doc-page {
    background: var(--color-light);
    padding: 64px 0 120px;
  }
  .doc-page__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .doc-nav {
    position: relative;
    margin-bottom: 40px;
    text-align: right;
  }
  .doc-nav__toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-steel);
    border: 1px solid var(--color-steel);
    border-radius: 6px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fafaf7;
    cursor: pointer;
    transition: opacity var(--transition);
  }
  .doc-nav__toggle:hover {
    opacity: 0.7;
  }
  .doc-nav__chevron {
    font-size: 10px;
  }
  .doc-nav__list {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 8px;
    background: var(--color-light);
    border: 1px solid rgba(13, 32, 24, 0.15);
    border-radius: 8px;
    padding: 12px 0;
    list-style: none;
    min-width: 280px;
    box-shadow: 0 8px 24px rgba(13, 32, 24, 0.12);
    z-index: 10;
  }
  .doc-nav__list--open {
    display: block;
  }
  .doc-nav__list li {
    margin: 0;
  }
  .doc-nav__link {
    display: block;
    padding: 8px 20px;
    font-size: 14px;
    color: var(--color-ink);
    text-decoration: none;
    transition: background var(--transition);
  }
  .doc-nav__link:hover {
    background: rgba(13, 32, 24, 0.04);
  }
  .doc-nav__link--active {
    font-weight: 600;
  }

  .doc-body {
    min-width: 0;
  }
  .doc-body__title {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--text-on-light);
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .doc-body__meta {
    font-size: 13px;
    color: var(--text-muted-on-light);
    margin-bottom: 4px;
  }
  .doc-body__meta--github {
    margin-bottom: 32px;
  }
  .doc-body__github {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--color-steel);
    text-decoration: none;
  }
  .doc-body__github:hover {
    text-decoration: underline;
  }

  .doc-metadata {
    margin: 0 0 40px;
    padding: 20px 24px;
    background: rgba(13, 32, 24, 0.04);
    border-left: 3px solid var(--color-steel);
    font-size: 13px;
  }
  .doc-metadata__row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 16px;
    padding: 4px 0;
  }
  .doc-metadata__row dt {
    color: var(--text-muted-on-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 11px;
    padding-top: 2px;
  }
  .doc-metadata__row dd {
    color: var(--text-on-light);
    margin: 0;
    line-height: 1.5;
  }

  .doc-body__content :global(h2) {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-on-light);
    letter-spacing: -0.3px;
    margin-top: 40px;
    margin-bottom: 12px;
  }
  .doc-body__content :global(h3) {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-on-light);
    margin-top: 28px;
    margin-bottom: 8px;
  }
  .doc-body__content :global(p) {
    font-size: 15px;
    color: var(--text-on-light);
    line-height: 1.7;
    margin-bottom: 12px;
    max-width: 760px;
  }
  .doc-body__content :global(ul) {
    font-size: 15px;
    color: var(--text-on-light);
    line-height: 1.7;
    margin-bottom: 16px;
    padding-left: 24px;
    max-width: 760px;
  }
  .doc-body__content :global(li) {
    margin-bottom: 4px;
  }
  .doc-body__content :global(a) {
    color: var(--color-steel);
    text-decoration: none;
  }
  .doc-body__content :global(a:hover) {
    text-decoration: underline;
  }
  .doc-body__content :global(strong) {
    font-weight: 700;
  }
  .doc-body__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0 32px;
    font-size: 13px;
  }
  .doc-body__content :global(th) {
    text-align: left;
    padding: 12px 16px;
    background: rgba(13, 32, 24, 0.05);
    color: var(--text-on-light);
    font-weight: 700;
    border-bottom: 1px solid rgba(13, 32, 24, 0.12);
  }
  .doc-body__content :global(td) {
    padding: 14px 16px;
    color: var(--text-on-light);
    border-bottom: 1px solid rgba(13, 32, 24, 0.08);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .doc-body__title {
      font-size: 28px;
    }
    .doc-metadata__row {
      grid-template-columns: 1fr;
      gap: 2px;
    }
  }
</style>
