---
import Layout from '../layouts/Layout.astro';

const policies = [
  { name: 'Information Security Policy', version: '', status: 'In development' },
  { name: 'Access Control Policy', version: '', status: 'In development' },
  { name: 'Incident Response Plan', version: '', status: 'In development' },
  { name: 'Vendor Risk Management Policy', version: '', status: 'In development' },
  { name: 'Data Retention Policy', version: '', status: 'In development' },
  { name: 'Business Continuity Plan', version: '', status: 'In development' }
];

const subprocessors = [
{ name: 'Sub-processor List', href: '/trust-center/sub-processor-list', version: 'v1.0 · May 2026', status: 'View document →' },  { name: 'Data Processing Agreement', version: '', status: 'In development' }
];
---

<Layout 
  title="Trust Center — Fenn Agritech"
  description="Fenn's policies, sub-processors, and supporting documents."
  currentPage="trust-center"
>
  <section class="trust-center">
    <div class="container">
      <p class="section-label">Policies</p>
      <div class="doc-list">
        {policies.map(doc => (
          <div class="doc-row">
            <div class="doc-row__left">
              <p class="doc-row__name">{doc.name}</p>
            </div>
            <div class="doc-row__middle">
              {doc.version && <p class="doc-row__version">{doc.version}</p>}
            </div>
            <div class="doc-row__right">
              <p class="doc-row__status">{doc.status}</p>
            </div>
          </div>
        ))}
      </div>

      <p class="section-label section-label--second">Sub-processors</p>
      <div class="doc-list">
         {subprocessors.map(doc => (
          <div class="doc-row">
            <div class="doc-row__left">
              {doc.href ? (
                <a href={doc.href} class="doc-row__name doc-row__name--link">{doc.name}</a>
              ) : (
                <p class="doc-row__name">{doc.name}</p>
              )}
            </div>
            <div class="doc-row__middle">
              {doc.version && <p class="doc-row__version">{doc.version}</p>}
            </div>
            <div class="doc-row__right">
              {doc.href ? (
                <a href={doc.href} class="doc-row__status doc-row__status--link">{doc.status}</a>
              ) : (
                <p class="doc-row__status">{doc.status}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .trust-center {
    background: var(--color-light);
    padding: 80px 0 120px;
  }

  .section-label {
    color: var(--color-emerald);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 24px;
    text-align: left;
  }

  .section-label--second {
    margin-top: 72px;
  }

  .doc-list {
    border-top: 1px solid rgba(13, 32, 24, 0.12);
  }

  .doc-row {
    display: grid;
    grid-template-columns: 1fr 200px 140px;
    gap: 32px;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid rgba(13, 32, 24, 0.12);
  }

  .doc-row__left {
    min-width: 0;
  }

  .doc-row__name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-on-light);
    letter-spacing: -0.3px;
    line-height: 1.3;
  }

  .doc-row__middle {
    text-align: left;
  }

  .doc-row__version {
    font-size: 13px;
    color: var(--text-muted-on-light);
  }

  .doc-row__right {
    text-align: right;
  }

  .doc-row__status {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-muted-on-light);
  }
  .doc-row__name--link {
    color: var(--text-on-light);
    transition: color var(--transition);
  }
  .doc-row__name--link:hover {
    color: var(--color-emerald);
  }
  .doc-row__status--link {
    color: var(--color-emerald);
    text-transform: uppercase;
    transition: opacity var(--transition);
  }
  .doc-row__status--link:hover {
    opacity: 0.7;
  }
  @media (max-width: 768px) {
    .doc-row {
      grid-template-columns: 1fr auto;
      gap: 8px;
      padding: 20px 0;
    }
    .doc-row__middle {
      display: none;
    }
    .doc-row__right {
      text-align: right;
    }
  }
</style>